# Frontend env (Vite). VITE_ prefiksli o'zgaruvchilarni client kodi ko'radi.
# Faylni `.env.local` yoki `.env.production` deb nusxalang.

# API base URL. Bo'sh qoldirilsa, "/api/v1" ishlatiladi (Vite/Nginx proxy orqali).
# Backend boshqa domen/portda bo'lsa to'liq URL kiriting:
#   VITE_API_BASE_URL=https://api.senariy.uz/api/v1
VITE_API_BASE_URL=

# Dev rejimida Vite proxy backendni qaysi manzilga jo'natadi (vite.config.ts).
# Bu Vite tomonida ishlatiladi, brauzerga uzatilmaydi.
VITE_DEV_PROXY_TARGET=http://localhost:8001
